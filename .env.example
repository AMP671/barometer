# Copy this to .env on the server (not on Mac / not committed) and fill in:

# Any password you like — this only protects the local Postgres container.
POSTGRES_PASSWORD=changeme

# Admiralty UK Tidal API key (Discovery tier) — used by the server-side
# proxy for official UK/Ireland tide predictions. Without it the app still
# works and every location falls back to the modeled tide curve.
# Get one at https://admiraltyapi.portal.azure-api.net/
ADMIRALTY_API_KEY=

# Optional: set to a short git commit hash on each deploy so the PWA
# force-reloads clients on iOS. If left unset, the server uses its process
# start time instead — every container rebuild/restart counts as a new
# version, which is usually all you need.
BUILD_ID=
