# Copy this to .env on the server (not on Mac / not committed) and fill in:

# Any password you like — this only protects the local Postgres container.
POSTGRES_PASSWORD=changeme

# Free key from https://openweathermap.org/api — only used for the isobar
# map tile layer. Weather readings themselves need no key (Open-Meteo).
OWM_API_KEY=

# Optional: bump this string on each deploy (e.g. a short git commit hash)
# so the PWA force-reloads on iOS instead of serving a cached version.
# If left unset, a container restart still counts as a new version.
BUILD_ID=
